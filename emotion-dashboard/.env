# 情绪愈疗平台 - 环境配置文件
# 请根据实际情况修改以下配置项

# ==================== Flask配置 ====================
FLASK_APP=api.py
FLASK_ENV=development
SECRET_KEY=emotion-dashboard-secret-key-2024

# ==================== MySQL数据库配置 ====================
# 请修改为你的MySQL连接信息
DB_HOST=localhost          # 数据库主机地址
DB_PORT=3306              # 数据库端口号
DB_NAME=emotion_db        # 数据库名称
DB_USER=root               # 数据库用户名
DB_PASSWORD=root1234       # 数据库密码

# ==================== AI服务配置（可选）====================
# 如果使用真实LLM API，配置以下参数
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-3.5-turbo
