# ========================================
# 情绪愈疗平台 - 环境配置文件
# ========================================
# 开发环境复制此文件为.env后修改对应值
# 生产环境在Railway后台配置环境变量
# ========================================

# ========== Flask应用配置 ==========
SECRET_KEY=emotion-healing-secret-key-2024
JWT_SECRET_KEY=jwt-secret-key-for-emotion-healing

# ========== 数据库配置 ==========
# 开发环境
DATABASE_URL=mysql+pymysql://root:root1234@localhost:3306/emotion_db

# 生产环境（在Railway中配置）
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname

# 数据库连接池（生产环境）
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ========== LLM API配置 ==========
DASHSCOPE_API_KEY=sk-cd1941be1ff64ce58eddb6e7bb69de71
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# ========== 邮件服务配置 ==========
# SMTP服务器配置（可选，用于风险预警邮件通知）
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your_email@qq.com
SMTP_PASSWORD=your_auth_code
ALERT_EMAIL=admin@example.com

# ========== 开发环境配置 ==========
DEBUG=True
FLASK_ENV=development
