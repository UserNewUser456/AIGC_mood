# 知识库管理工具 - 低内存版本
# 适合2GB内存服务器
FROM python:3.9-slim

# 设置工作目录
WORKDIR /app

# 设置环境变量（低内存优化）
ENV OMP_NUM_THREADS=1
ENV MKL_NUM_THREADS=1
ENV OPENBLAS_NUM_THREADS=1
ENV NUMEXPR_NUM_THREADS=1
ENV PYTHONUNBUFFERED=1

# 复制依赖文件
COPY requirements_knowledge.txt .

# 安装依赖
RUN pip install --no-cache-dir -r requirements_knowledge.txt

# 复制应用代码
COPY knowledge_manager.py .
COPY knowledge_manager_ext.py .
COPY test_knowledge_manager.py .

# 创建必要的目录
RUN mkdir -p knowledge_vector_db knowledge_uploads logs

# 暴露端口（如果使用Flask API）
EXPOSE 5005

# 默认命令
CMD ["python3", "test_knowledge_manager.py"]
